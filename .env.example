# Copy to .env (repo root). Never commit .env — it holds secrets.
# Docker Compose auto-reads this file for ${VAR} substitution.

# --- Postgres (used by the db service and to build the container DATABASE_URL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=tasker-dev

# --- App ---
PORT=5001

# DATABASE_URL is only used when running the app on the HOST (go run), pointing
# at the published db port (5555). Inside docker compose the app builds its own
# URL against the internal db:5432 — see docker-compose.yml, so this value is
# ignored there.
DATABASE_URL=postgres://postgres:change-me@localhost:5555/tasker-dev?sslmode=disable

# --- Telegram delivery (server) ---
# Bot token from @BotFather; chat id is your personal chat with the bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- PC watcher (tasker-watch) ---
# Absolute path to the TODO.md to watch, and the API base URL to push to.
TODO_FILE_PATH=/home/ken/TODO.md
TASKER_API_URL=http://localhost:5001

# --- /api/sync auth ---
# Shared secret. When set, the server requires it and the watcher sends it.
# Leave empty only for local-only runs (server logs a warning).
SYNC_TOKEN=

# Pending approval before use (see CONTEXT.md tool policy):
#   LLM_API_KEY=
